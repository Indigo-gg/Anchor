{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "ES2022"
        ],
        "module": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "composite": true,
        "outDir": "./dist-electron"
    },
    "include": [
        "vite.config.ts",
        "electron/**/*.ts"
    ]
}